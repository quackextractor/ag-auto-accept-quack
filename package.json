{
  "name": "ag-auto-accept-quack",
  "displayName": "Antigravity Auto Accept Quack",
  "description": "Automatically accepts Antigravity agent steps without limits, using DOM text-matching for newer versions.",
  "version": "1.3.2",
  "icon": "icon.png",
  "publisher": "quackextractor",
  "repository": {
    "type": "git",
    "url": "https://github.com/quackextractor/ag-auto-accept-quack"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "categories": [
    "Other"
  ],
  "scripts": {
    "test": "node tests/extension.test.js",
    "lint": "eslint ."
  },
  "contributes": {
    "configuration": {
      "title": "Quack Auto-Accept",
      "properties": {
        "quack-auto-accept.interval": {
          "type": "number",
          "default": 1500,
          "description": "Interval in milliseconds to check for Accept/Run buttons."
        }
      }
    },
    "commands": [
      {
        "command": "unlimited.toggle",
        "title": "Toggle Unlimited Auto-Accept (Quack)"
      },
      {
        "command": "quack-auto-accept.setInterval",
        "title": "Quack Auto-Accept: Set Interval"
      }
    ],
    "keybindings": [
      {
        "command": "unlimited.toggle",
        "key": "ctrl+alt+shift+u",
        "mac": "cmd+alt+shift+u"
      }
    ]
  },
  "devDependencies": {
    "eslint": "^8.0.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
